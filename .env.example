# Copy this file to ".env" and fill in your own values.
#
# 1. Go to https://supabase.com and create a free project.
# 2. In your project: Settings -> API
# 3. Copy "Project URL"  -> SUPABASE_URL
# 4. Copy "anon public"  -> SUPABASE_ANON_KEY
# 5. Run src/db/schema.sql in the Supabase SQL Editor.
# 6. Create a public Storage bucket named "designs".

PORT=3000
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Get the service role key from: Supabase Dashboard -> Settings -> API -> Project API keys -> service_role
# Required for admin APIs to work correctly (bypasses RLS for admin operations)
SUPABASE_SERVICE_KEY=your-service-role-key
